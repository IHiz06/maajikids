# ============================================================
# MaajiKids Backend — Variables de Entorno (.env.example)
# Copia este archivo como .env y rellena tus valores reales.
# ============================================================

# ---------- Flask ----------
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga-y-aleatoria

# ---------- Base de Datos (Supabase PostgreSQL) ----------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ---------- JWT ----------
JWT_SECRET_KEY=cambia-esto-por-otra-clave-jwt-secreta
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutos en segundos
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 días en segundos

# ---------- Cifrado AES-256 (Fernet) ----------
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=tu-clave-fernet-base64-aqui

# ---------- Email (Flask-Mailman) ----------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-app-password-gmail
MAIL_DEFAULT_SENDER=MaajiKids <tu-correo@gmail.com>

# ---------- MercadoPago Checkout Pro ----------
MP_ACCESS_TOKEN=TEST-xxxx-xxxx-xxxx-xxxx         # sandbox: TEST-, producción: APP_USR-
MP_PUBLIC_KEY=TEST-xxxx-xxxx-xxxx-xxxx
MP_SUCCESS_URL=http://localhost:3000/pago/exito
MP_FAILURE_URL=http://localhost:3000/pago/fallo
MP_PENDING_URL=http://localhost:3000/pago/pendiente

# ---------- Google Gemini 2.5 Flash ----------
GEMINI_API_KEY=tu-api-key-de-google-ai-studio

# ---------- Cloudinary (imágenes talleres y niños) ----------
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ---------- Supabase (Storage para DNI) ----------
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key   # service_role key (NO la anon key)

# ---------- Frontend URL (CORS) ----------
FRONTEND_URL=http://localhost:3000

# ---------- Logo institucional ----------
LOGO_PATH=static/logo/maajikids_logo.png
